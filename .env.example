# --- LLM (only the answer step needs this; embeddings run locally) ---
OPENAI_API_KEY=your_openai_api_key

# Optional: override the default answer model. Any init_chat_model id works,
# e.g. "openai:gpt-4.1" or "ollama:llama3.1"
# LLM_MODEL=openai:gpt-4.1

# --- Retrieval (all local, no API key) ---
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CHROMA_PATH=./chroma_db
# CHROMA_COLLECTION=docagent
# TOP_K=4
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=150

# --- Optional: per-sentence citation entailment (verify the answer is grounded) ---
# off (default) | nli (local cross-encoder, no API key) | llm (one grading call)
# ENTAILMENT_BACKEND=off
# NLI_MODEL=cross-encoder/nli-deberta-v3-base

# --- Optional: web API hardening (docagent.web) ---
# When set, /api/* requires header `X-API-Key: <this>`. Unset = open (dev).
# DOCAGENT_API_KEY=change-me
# Per-client fixed-window rate limit:
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW=60

# --- Optional: logging ---
# LOG_LEVEL=INFO

# --- Optional: LangSmith tracing ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=docagent
